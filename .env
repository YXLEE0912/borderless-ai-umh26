# Agent2 GLM config
GLM_API_KEY=xxx
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4

# Optional project tag
PROJECT_ID=borderless_ai_001

# Gemini test key
GEMINI_API_KEY=xxxx

# Frontend to Agent2 backend bridge
VITE_USE_AGENT2_BACKEND=false
VITE_AGENT2_API_BASE_URL=http://127.0.0.1:8000
VITE_AGENT2_POLICY_TOPIC=K2 Forms

# Optional: Ilmu Anthropic proxy (only if you switch from GLM)
ANTHROPIC_BASE_URL=https://api.ilmu.ai/anthropic
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=
