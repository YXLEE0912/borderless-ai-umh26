# -------------------------------
# Frontend URL (used by CORS)
# In development, Vite proxy handles routing — leave empty or set to Vite URL
# -------------------------------
FRONTEND_URL=http://localhost:5173
VITE_API_URL=

# Note: Set VITE_API_URL to empty string "" so Vite proxy is used.
# The proxy in vite.config.ts forwards /sessions, /chat, etc. to http://localhost:8000
# This eliminates all CORS issues in development.

