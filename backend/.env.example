APP_NAME=Borderless AI API
API_PREFIX=/api/v1

# Z.ai model provider
UMH_3_API_KEY=
A_AI_API_KEY=
AI_API_KEY=
Z_AI_API_KEY=
Z_AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
Z_AI_MODEL=glm-4.5v
Z_AI_TIMEOUT_SECONDS=90
Z_AI_MAX_RETRIES=2
Z_AI_FALLBACK_MODELS=["ilmu-glm-5.1"]
Z_AI_MAX_TOKENS=700

# Gemini Vision (multimodal image understanding)
GEMINI_API_KEY=
GEMINI_API_KEY_BACKUP=
GEMINI_VISION_MODEL=gemini-2.5-flash


# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=scan-assets

# Runtime tables
SUPABASE_SCANS_TABLE=scans
SUPABASE_SCAN_CHAT_MESSAGES_TABLE=scan_chat_messages

# Runtime tuning
RULES_CACHE_TTL_SECONDS=60
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8080","http://127.0.0.1:8080"]