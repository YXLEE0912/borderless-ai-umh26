APP_NAME=Borderless AI API
API_PREFIX=/api/v1

Z_AI_API_KEY=
Z_AI_BASE_URL=https://api.ilmu.ai/v1
# Change this to a model that your Z.ai console actually enables for your team.
# Common options depend on the account; start with the model listed in your hackathon email,
# then try the provider-approved fallback if the API returns HTTPStatusError.
Z_AI_MODEL=ilmu-glm-5.1

STT_API_KEY=
STT_BASE_URL=
STT_MODEL=whisper-1

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=scan-assets
SUPABASE_SCANS_TABLE=scans
SUPABASE_RULESETS_TABLE=regulatory_rulesets
SUPABASE_RULES_TABLE=regulatory_rules
SUPABASE_DESTINATION_POLICIES_TABLE=destination_policies
SUPABASE_DOCUMENT_PROFILES_TABLE=document_profiles
SUPABASE_RULE_EXECUTION_LOG_TABLE=rule_execution_log

RULES_CACHE_TTL_SECONDS=60

CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]