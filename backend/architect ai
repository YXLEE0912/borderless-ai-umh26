"""
Compliance Service - Malaysian export regulation checks
"""

import json
from typing import Dict, Any
from glmservice import GLMService


class ComplianceService:
    def __init__(self, glm: GLMService):
        self.glm = glm

    async def full_compliance_check(self, session_data: Dict[str, Any]) -> Dict[str, Any]:
        """Run a full compliance check across all session data"""
        system = """You are a Malaysian Customs and Trade Compliance auditor.
        Review the complete export session and identify ALL compliance gaps.
        Respond in JSON: {
            "overall_status": "compliant|non_compliant|pending",
            "compliance_score": 0-100,
            "critical_issues": [],
            "warnings": [],
            "passed_checks": [],
            "estimated_delay_days": 0,
            "regulatory_citations": []
        }"""

        return await self.glm.chat_json(system, json.dumps(session_data))

    async def check_restricted_goods(self, hs_code: str, destination: str) -> Dict[str, Any]:
        system = """You are a Malaysian Strategic Goods Control expert.
        Check if goods are restricted, controlled, or prohibited for export.
        Reference: Strategic Goods (Control) Act 2010, Customs (Prohibition of Exports) Order.
        Respond in JSON: {
            "restricted": false,
            "prohibited": false,
            "strategic_goods": false,
            "dual_use": false,
            "permits_required": [],
            "relevant_laws": []
        }"""

        return await self.glm.chat_json(
            system, f"HS Code: {hs_code}, Destination: {destination}"
        )

    async def check_fta_eligibility(
        self, hs_code: str, origin: str, destination: str
    ) -> Dict[str, Any]:
        system = """You are a Free Trade Agreement specialist for Malaysia.
        Check FTA eligibility (ASEAN, CPTPP, MAFTA, etc.) and Form D/E/AI requirements.
        Respond in JSON: {
            "fta_applicable": [],
            "preferential_rate": 0.0,
            "mfn_rate": 0.0,
            "savings_potential_percent": 0.0,
            "form_required": "Form D|Form E|RCEP Form|None",
            "roo_requirements": [],
            "local_content_threshold": 0
        }"""

        return await self.glm.chat_json(
            system, f"HS: {hs_code}, From: {origin}, To: {destination}"
        )


# ─────────────────────────────────────────────────────────────
# DOCUMENT SERVICE
# ─────────────────────────────────────────────────────────────

class DocumentService:

    async def generate_all_documents(
        self, session, glm: GLMService
    ) -> Dict[str, Any]:
        """Generate all required trade documents"""
        docs = {}

        tasks = [
            ("commercial_invoice", self._generate_commercial_invoice(session, glm)),
            ("packing_list", self._generate_packing_list(session, glm)),
            ("certificate_of_origin", self._generate_cert_of_origin(session, glm)),
        ]

        for doc_name, coro in tasks:
            try:
                docs[doc_name] = await coro
            except Exception as e:
                docs[doc_name] = {"error": str(e), "status": "failed"}

        return docs

    async def _generate_commercial_invoice(
        self, session, glm: GLMService
    ) -> Dict[str, Any]:
        system = """Generate a complete Malaysian export commercial invoice.
        Respond in JSON with all invoice fields following Malaysian customs requirements."""

        entity = session.checklist.get("entity_verification", {})
        consignee = session.checklist.get("consignee", {})
        classification = session.checklist.get("classification", {})
        valuation = session.checklist.get("financial_valuation", {})

        return await glm.chat_json(system, f"""
        Exporter: {entity.get('company_name')} BRN: {entity.get('brn')}
        Consignee: {consignee.get('buyer_name')}, {consignee.get('country')}
        Product: {classification.get('product_description')} HS: {classification.get('hs_code')}
        FOB Value: MYR {valuation.get('fob_myr', 0)}
        Incoterm: {consignee.get('incoterm', 'FOB')}
        """)

    async def _generate_packing_list(
        self, session, glm: GLMService
    ) -> Dict[str, Any]:
        system = """Generate a complete packing list for Malaysian customs export.
        Respond in JSON with all required packing list fields."""

        logistics = session.checklist.get("logistics", {})
        return await glm.chat_json(system, f"""
        Mode: {logistics.get('mode')}
        Weight: {logistics.get('weight_kg')} kg, CBM: {logistics.get('cbm')}
        Generate standard Malaysian export packing list.
        """)

    async def _generate_cert_of_origin(
        self, session, glm: GLMService
    ) -> Dict[str, Any]:
        system = """Generate a Certificate of Origin for Malaysian export (Form D/ATIGA or standard CO).
        Respond in JSON with all CO fields as per MITI/MATRADE requirements."""

        entity = session.checklist.get("entity_verification", {})
        consignee = session.checklist.get("consignee", {})
        classification = session.checklist.get("classification", {})

        return await glm.chat_json(system, f"""
        Exporter: {entity.get('company_name')}
        Destination: {consignee.get('country')}
        Product: {classification.get('product_description')}
        HS Code: {classification.get('hs_code')}
        """)


# ─────────────────────────────────────────────────────────────
# LANDED COST SERVICE
# ─────────────────────────────────────────────────────────────

class LandedCostService:

    async def calculate_landed_cost(
        self,
        fob_myr: float,
        freight_myr: float,
        insurance_rate: float,
        import_duty_rate: float,
        destination: str,
        hs_code: str,
        glm_service: GLMService,
    ) -> Dict[str, Any]:
        """Calculate complete landed cost with GLM validation"""

        insurance_myr = fob_myr * insurance_rate
        cif_myr = fob_myr + freight_myr + insurance_myr
        estimated_duty_myr = cif_myr * import_duty_rate
        total_landed_myr = cif_myr + estimated_duty_myr

        # Check ATIGA Form D savings potential
        system = """You are a Malaysian trade FTA savings specialist.
        Calculate potential duty savings using available FTAs.
        Respond in JSON: {
            "atiga_applicable": false,
            "atiga_savings_myr": 0,
            "cptpp_applicable": false,
            "cptpp_savings_myr": 0,
            "best_fta": "",
            "best_fta_savings_myr": 0,
            "notes": ""
        }"""

        fta_result = await glm_service.chat_json(
            system,
            f"HS Code: {hs_code}, Destination: {destination}, CIF: MYR {cif_myr:.2f}, Duty Rate: {import_duty_rate*100:.1f}%"
        )

        return {
            "fob_myr": round(fob_myr, 2),
            "freight_myr": round(freight_myr, 2),
            "insurance_myr": round(insurance_myr, 2),
            "cif_myr": round(cif_myr, 2),
            "import_duty_rate": import_duty_rate,
            "estimated_duty_myr": round(estimated_duty_myr, 2),
            "total_landed_cost_myr": round(total_landed_myr, 2),
            "fta_savings": fta_result,
            "atiga_savings_myr": fta_result.get("atiga_savings_myr", 0),
            "is_final": False,
            "note": "Updates as you progress through steps",
        }