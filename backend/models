"""
Pydantic models for Borderless AI Trade Platform
"""

from pydantic import BaseModel
from typing import Optional, List, Dict, Any
from datetime import datetime


class ChatMessage(BaseModel):
    role: str  # user | assistant
    content: str
    ts: str


class ExportSession(BaseModel):
    session_id: str
    created_at: datetime
    current_step: int = 1
    progress: int = 0
    chat_history: List[Dict[str, str]] = []
    checklist: Dict[str, Any] = {}
    documents: Dict[str, Any] = {}
    landed_cost: Optional[Dict[str, Any]] = None


class EntityVerification(BaseModel):
    company_name: str
    registration_number: str
    director_nric: Optional[str] = None
    ssm_certificate_uploaded: bool = False
    status: str = "pending"  # pending | verified | failed


class ConsigneeDetails(BaseModel):
    buyer_name: str
    buyer_country: str
    buyer_address: str
    importer_of_record: Optional[str] = None
    buyer_tax_id: Optional[str] = None
    incoterm: str = "FOB"


class HSClassification(BaseModel):
    product_description: str
    hs_code: Optional[str] = None
    destination_country: str
    export_duty_rate: float = 0.0
    import_duty_rate: float = 0.0
    fta_applicable: List[str] = []


class SpecialPermits(BaseModel):
    sirim_required: bool = False
    halal_required: bool = False
    miti_required: bool = False
    permits: List[Dict[str, Any]] = []


class FinancialValuation(BaseModel):
    fob_value_myr: float
    freight_myr: float
    insurance_myr: float
    cif_myr: float
    estimated_duty_myr: float
    total_landed_cost_myr: float
    currency: str = "MYR"
    atiga_savings_myr: float = 0.0


class LogisticsMetrics(BaseModel):
    mode: str  # sea | air | land
    vessel_name: Optional[str] = None
    port_of_loading: str
    port_of_discharge: str
    gross_weight_kg: float
    cbm: float


class TradeDoc(BaseModel):
    doc_type: str
    content: Dict[str, Any]
    generated_at: str
    status: str = "draft"  # draft | signed | submitted


class DocumentStatus(BaseModel):
    name: str
    status: str  # locked | required | ready | generated | submitted
    steps_remaining: int = 0
    locked: bool = True